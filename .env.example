# Beispiel-Konfiguration fuer den Fahrverein Planetal e.V.
# Kopiere diese Datei nach ".env" und passe die Werte an.
# Die echte ".env" wird NICHT eingecheckt (siehe .gitignore).

# Anzeigename der Anwendung (Titel, SEO, Footer).
APP_NAME="Fahrverein Planetal e.V."

# Geheimer Schluessel fuer Sessions/CSRF. In Produktion zwingend
# durch einen langen Zufallswert ersetzen (z. B. `python -c "import secrets; print(secrets.token_hex(32))"`).
SECRET_KEY="bitte-aendern"

# --- E-Mail-Versand (Kontaktformular) -------------------------------
# Ist MAIL_SERVER leer, wird der Versand deaktiviert und das
# Kontaktformular zeigt einen freundlichen mailto-Hinweis.
#
# Beispiel STRATO/WEB.DE (SMTP mit STARTTLS auf Port 587):
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
# Absenderadresse (Default = MAIL_USERNAME). Sollte zum SMTP-Konto passen.
MAIL_DEFAULT_SENDER=
# Empfaenger der Kontaktanfragen.
CONTACT_RECIPIENT=fvplanetal@web.de
