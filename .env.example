# Flask Konfiguration
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an

# WICHTIG: Geheimer Schlüssel für Sessions (unbedingt ändern!)
# Generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ihr-geheimer-schluessel-hier

# Datenbank-URL (Standard: SQLite)
# Für PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///app.db

# Anwendungsname (erscheint im Browser-Tab)
APP_NAME=Fahrverein Planetal e.V.

# Basis-URL für SEO (Sitemap, Canonical URLs)
BASE_URL=https://fahrverein-planetal.de

# Wartungsmodus (True/False)
MAINTENANCE_MODE=False

# Session-Cookie Sicherheit
# Auf False setzen für lokale Entwicklung ohne HTTPS
SESSION_COOKIE_SECURE=True

# Rate Limiting (True/False)
# Deaktivieren für lokale Entwicklung falls nötig
RATELIMIT_ENABLED=True

# Flask Debug-Modus (nur für Entwicklung!)
FLASK_DEBUG=False
