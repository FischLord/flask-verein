{
  "name": "flask-verein-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind/Flowbite Build-Pipeline fuer die Fahrverein-Planetal-Website (kein Runtime-Node, nur Build-Step).",
  "scripts": {
    "build:css": "tailwindcss -i ./app/static/css/input.css -o ./app/static/css/app.css --minify",
    "watch:css": "tailwindcss -i ./app/static/css/input.css -o ./app/static/css/app.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "flowbite": "^2.5.2",
    "flowbite-typography": "^1.0.5",
    "tailwindcss": "^3.4.14"
  }
}
